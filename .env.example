# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
SAGEMAKER_ROLE=arn:aws:iam::123456789012:role/SageMakerRole
S3_BUCKET=your-bucket-name

# Model Configuration
MODEL_PATH=models/xgboost_model.pkl
FEATURE_ARTIFACTS_PATH=data/processed/feature_artifacts.pkl

# API Configuration
FLASK_ENV=development
FLASK_APP=src/deployment/api.py
API_HOST=0.0.0.0
API_PORT=5000

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/credit_risk

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# Monitoring
ENABLE_LOGGING=true
LOG_LEVEL=INFO

# SageMaker Endpoint
SAGEMAKER_ENDPOINT_NAME=credit-risk-endpoint
SAGEMAKER_INSTANCE_TYPE=ml.t2.medium

# Feature Flags
USE_SMOTE=false
ENABLE_SHAP_EXPLANATIONS=true

# Slack Notifications (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
